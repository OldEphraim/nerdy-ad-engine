# ── REQUIRED ──────────────────────────────────────────────────────────────
# Your Anthropic API key — get one at console.anthropic.com
ANTHROPIC_API_KEY=

# ── MODEL CONFIGURATION ───────────────────────────────────────────────────
# Model used for ad copy generation (creative, temperature=0.7)
GENERATOR_MODEL=claude-haiku-4-5

# Model used for LLM-as-judge evaluation (deterministic, temperature=0)
# Can be the same model as GENERATOR_MODEL for V1
EVALUATOR_MODEL=claude-haiku-4-5

# ── PIPELINE CONFIGURATION ────────────────────────────────────────────────
# Maximum iteration cycles before giving up on a brief
MAX_ITERATIONS=5

# Minimum aggregate score (out of 10) for an ad to be considered publishable
QUALITY_THRESHOLD=7.0

# Max concurrent API calls — keep at 5 to avoid rate limit errors
CONCURRENCY_LIMIT=5
