# ── REQUIRED ──────────────────────────────────────────────────────────────
# Your Anthropic API key — get one at console.anthropic.com
ANTHROPIC_API_KEY=

# ── MODEL CONFIGURATION ───────────────────────────────────────────────────
# Model used for ad copy generation (creative, temperature=0.7)
GENERATOR_MODEL=claude-haiku-4-5

# Model used for LLM-as-judge evaluation (deterministic, temperature=0)
# Can be the same model as GENERATOR_MODEL for V1
EVALUATOR_MODEL=claude-haiku-4-5

# ── PIPELINE CONFIGURATION ────────────────────────────────────────────────
# Maximum iteration cycles before giving up on a brief
MAX_ITERATIONS=5

# Minimum aggregate score (out of 10) for an ad to be considered publishable
QUALITY_THRESHOLD=7.0

# Max concurrent API calls — keep at 5 to avoid rate limit errors
CONCURRENCY_LIMIT=5

# ── V2: IMAGE GENERATION ──────────────────────────────────────────────────
# Your fal.ai API key — get one at fal.ai/dashboard
FAL_KEY=

# fal.ai model ID for image generation (Flux Schnell is fast and cheap at ~$0.003/image)
IMAGE_MODEL=fal-ai/flux/schnell

# Model used for visual evaluation — must be vision-capable (Sonnet, not Haiku)
VISUAL_EVALUATOR_MODEL=claude-sonnet-4-5

# Number of image variants to generate per passing ad (A/B selection picks the best)
IMAGE_VARIANTS=2

# Output image dimensions in pixels — 1200x628 is Facebook link format (1.91:1 ratio)
IMAGE_WIDTH=1200
IMAGE_HEIGHT=628

# ── V2: COMBINED SCORING ──────────────────────────────────────────────────
# Weight applied to the text evaluation score in the combined ad score
# Text drives Meta ad performance more than visuals, so text is weighted higher
TEXT_SCORE_WEIGHT=0.6

# Weight applied to the visual evaluation score in the combined ad score
# Must sum to 1.0 with TEXT_SCORE_WEIGHT
IMAGE_SCORE_WEIGHT=0.4

# ── V3: COHERENCE LOOP ────────────────────────────────────────────────────
# Enable/disable the third-variant coherence improvement loop
COHERENCE_LOOP_ENABLED=true

# Trigger coherence loop if text_image_coherence scores below this threshold
COHERENCE_THRESHOLD=7.5

# ── V3: COPY REFINEMENT ───────────────────────────────────────────────────
# Enable/disable copy-side refinement from visual feedback
COPY_REFINEMENT_ENABLED=true

# Trigger copy refinement if coherence is still below this after the image loop
COPY_REFINEMENT_THRESHOLD=7.0

# ── V3: QUALITY RATCHET ───────────────────────────────────────────────────
# Enable/disable dynamic few-shot examples from top library ads
RATCHET_ENABLED=true

# Minimum combined score for an ad to enter the ratchet pool
RATCHET_MIN_SCORE=8.0

# Maximum number of ads in the ratchet pool
RATCHET_POOL_SIZE=10

# ── V3: RESEARCHER AGENT ─────────────────────────────────────────────────
# Model for competitive intelligence (must support web search tool)
RESEARCHER_MODEL=claude-sonnet-4-5

# Cache competitive intelligence within a run (recommended — avoids 75x web search calls)
RESEARCHER_CACHE=true
